{
  "items": [
    {
      "id": "M001",
      "name": "mysql-select-limit-comma",
      "sql": "SELECT `u`.`id`, \"hello\" AS `label` FROM `users` AS `u` WHERE `u`.`id` = 1 LIMIT 5, 10",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "tables": ["users"],
        "selected_columns": ["id"],
        "where_columns": ["id"],
        "deparse_contains": "LIMIT 5, 10"
      }
    },
    {
      "id": "M002",
      "name": "mysql-select-join",
      "sql": "SELECT `u`.`id`, `u`.`name`, `o`.`order_no` FROM `users` `u` JOIN `orders` `o` ON `u`.`id` = `o`.`user_id` WHERE `o`.`status` = \"paid\"",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "tables": ["users", "orders"],
        "selected_columns": ["id", "name", "order_no"],
        "join_columns": ["id", "user_id"],
        "where_columns": ["status"],
        "deparse_contains": "JOIN orders o"
      }
    },
    {
      "id": "M003",
      "name": "mysql-hash-comment",
      "sql": "SELECT 1 # mysql line comment\n",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "deparse_contains": "SELECT 1"
      }
    },
    {
      "id": "M004",
      "name": "mysql-insert-values-multi-row",
      "sql": "INSERT INTO `users` (`id`, `name`) VALUES (1, \"bob\"), (2, 'alice')",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["InsertStmt", "SelectStmt"],
        "tables": ["users"],
        "insert_columns": ["id", "name"],
        "deparse_contains": "VALUES (1, 'bob'), (2, 'alice')"
      }
    },
    {
      "id": "M005",
      "name": "mysql-insert-select",
      "sql": "INSERT INTO `archive_users` (`id`, `name`) SELECT `id`, `name` FROM `users` WHERE `status` = \"inactive\"",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["InsertStmt", "SelectStmt"],
        "tables": ["archive_users", "users"],
        "selected_columns": ["id", "name"],
        "where_columns": ["status"],
        "insert_columns": ["id", "name"],
        "deparse_contains": "INSERT INTO archive_users"
      }
    },
    {
      "id": "M006",
      "name": "mysql-update-basic",
      "sql": "UPDATE `users` SET `name` = \"carol\", `status` = 'active' WHERE `id` = 1",
      "expect": {
        "ok": true,
        "statement_count": 1,
        "statement_types": ["UpdateStmt"],
        "tables": ["users"],
        "update_columns": ["name", "status"],
        "where_columns": ["id"],
        "deparse_contains": "UPDATE users SET"
      }
    },
    {
      "id": "M007",
      "name": "mysql-delete-conditional",

	@if not exist $(BIN_DIR)\examples\inspect mkdir $(BIN_DIR)\examples\inspect
	$(CC) $(CFLAGS) /Fe$@ examples\inspect\01_select_inspect.c /link $(LDFLAGS) $(LDLIBS)


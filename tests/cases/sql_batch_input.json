    },
    {
      "name": "create-table-as",
      "sql": "CREATE TABLE public.active_users AS SELECT id FROM public.users WHERE status = 'active'",
      "expect": {
        "statement_count": 1,
        "statement_types": ["CreateTableAsStmt", "SelectStmt"],
        "deparse_contains": "CREATE TABLE public.active_users AS"

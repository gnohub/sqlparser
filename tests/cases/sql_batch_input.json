{
  "items": [
    {
      "name": "select-basic",
      "sql": "SELECT 1",
      "expect": {
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "keywords": ["select"],
        "deparse_contains": "SELECT 1"
      }
    },
    {
      "name": "select-filter",
      "sql": "SELECT id, name FROM public.users WHERE id = 42",
      "expect": {
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "keywords": ["select", "from", "where"],
        "tables": ["public.users"],
        "selected_columns": ["id", "name"],
        "where_columns": ["id"],
        "all_referenced_columns": ["id", "name"],
        "deparse_contains": "FROM public.users"
      }
    },
    {
      "name": "select-join",
      "sql": "SELECT u.id, u.name, o.order_no FROM public.users u JOIN public.orders o ON u.id = o.user_id WHERE o.status = 'paid'",
      "expect": {
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "keywords": ["select", "from", "join", "on", "where"],
        "tables": ["public.users", "public.orders"],
        "selected_columns": ["id", "name", "order_no"],
        "join_columns": ["id", "user_id"],
        "where_columns": ["status"],
        "all_referenced_columns": ["id", "name", "order_no", "user_id", "status"],
        "deparse_contains": "SELECT u.id, u.name, o.order_no"
      }
    },
    {
      "name": "select-cte",
      "sql": "WITH active_users AS (SELECT id, name FROM public.users WHERE status = 'active') SELECT au.id, au.name FROM active_users au",
      "expect": {
        "statement_count": 1,
        "statement_types": ["SelectStmt"],
        "keywords": ["with", "select", "from", "where"],
        "tables": ["public.users"],
        "cte_names": ["active_users"],
        "selected_columns": ["id", "name"],
        "filter_columns": ["status"],
        "all_referenced_columns": ["id", "name"],
        "deparse_contains": "WITH active_users AS"
      }
    },
    {
      "name": "insert-single-row",
      "sql": "INSERT INTO public.users (id, name) VALUES (1, 'alice')",
      "expect": {
        "statement_count": 1,
        "statement_types": ["InsertStmt", "SelectStmt"],
        "keywords": ["insert", "into", "values"],
        "tables": ["public.users"],
        "insert_columns": ["id", "name"],
        "all_referenced_columns": ["id", "name"],
        "deparse_contains": "VALUES (1, 'alice')"
      }
    },
    {
      "name": "insert-multi-row",
      "sql": "INSERT INTO public.users (id, name) VALUES (1, 'alice'), (2, 'bob')",
      "expect": {
        "statement_count": 1,
        "statement_types": ["InsertStmt", "SelectStmt"],
        "keywords": ["insert", "into", "values"],
        "tables": ["public.users"],
        "insert_columns": ["id", "name"],
        "all_referenced_columns": ["id", "name"],
        "deparse_contains": "VALUES (1, 'alice'), (2, 'bob')"
      }
    },
    {
      "name": "insert-from-select",
      "sql": "INSERT INTO public.user_archive (id, name) SELECT id, name FROM public.users WHERE status = 'inactive'",
      "expect": {
        "statement_count": 1,
        "statement_types": ["InsertStmt", "SelectStmt"],
        "keywords": ["insert", "into", "select", "from", "where"],
        "tables": ["public.user_archive", "public.users"],
        "selected_columns": ["id", "name"],
        "where_columns": ["status"],
        "insert_columns": ["id", "name"],
        "all_referenced_columns": ["id", "name", "status"],
        "deparse_contains": "INSERT INTO public.user_archive"
      }
    },
    {
      "name": "update-basic",
      "sql": "UPDATE public.users SET name = 'alice', status = 'active' WHERE id = 1",
      "expect": {
        "statement_count": 1,
        "statement_types": ["UpdateStmt"],
        "keywords": ["update", "set", "where"],
        "tables": ["public.users"],
        "update_columns": ["name", "status"],
        "where_columns": ["id"],
        "all_referenced_columns": ["name", "status", "id"],
        "deparse_contains": "UPDATE public.users SET"
      }
    },
    {
      "name": "delete-conditional",
      "sql": "DELETE FROM public.users WHERE id = 1 AND status = 'active'",
      "expect": {
        "statement_count": 1,
        "statement_types": ["DeleteStmt"],
        "keywords": ["delete", "from", "where", "and"],
        "tables": ["public.users"],
        "where_columns": ["id", "status"],
        "all_referenced_columns": ["id", "status"],
        "deparse_contains": "DELETE FROM public.users"
      }
    },
    {
      "name": "delete-in-list",
      "sql": "DELETE FROM public.users WHERE id IN (1, 2, 3) AND status = 'active'",
      "expect": {
        "statement_count": 1,
        "statement_types": ["DeleteStmt"],
        "keywords": ["delete", "from", "where", "in", "and"],
        "tables": ["public.users"],
        "where_columns": ["id", "status"],
        "all_referenced_columns": ["id", "status"],
        "deparse_contains": "id IN (1, 2, 3)"
      }
